@model Society_Management_System.Models.Member

@{
    Layout = null;
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI',sans-serif;
        background: linear-gradient(rgba(0,0,0,0.55),rgba(0,0,0,0.55)),url('/images/addhouse.png');
        background-size: cover;
        background-position: center;
    }

    /* TITLE */

    h2 {
        text-align: center;
        margin-top: 30px;
        color: white;
        font-weight: 700;
    }

    /* GLASS PROFILE CARD */

    .profile-container {
        width: 450px;
        margin: 40px auto;
        padding: 30px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        text-align: center;
        color: white;
    }

    /* PROFILE IMAGE */

    .profile-img {
        width: 110px;
        height: 110px;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
        margin-bottom: 15px;
    }

    /* TABLE */

    .table {
        color: white;
    }

    .table-bordered {
        border-color: rgba(255,255,255,0.3);
    }

    .label {
        font-weight: 600;
    }

    /* BUTTON GROUP */

    .btn-group {
        margin-top: 18px;
        display: flex;
        justify-content: center;
        gap: 10px;
        flex-wrap: wrap;
    }

    /* WHITE BUTTONS */

    .btn-white {
        background: white;
        color: black;
        border: none;
        border-radius: 8px;
        padding: 8px 16px;
    }

        .btn-white:hover {
            background: white;
            transform: scale(1.05);
        }

</style>

<h2>My Profile</h2>

<div class="profile-container">

    @if (!string.IsNullOrEmpty(Model.Image))
    {
        <img src="~/images/@Model.Image" class="profile-img" />
    }

    <table class="table table-bordered">

        <tr>
            <td class="label">Name</td>
            <td>@Model.Name</td>
        </tr>

        <tr>
            <td class="label">Email</td>
            <td>@Model.Email</td>
        </tr>

        <tr>
            <td class="label">Mobile</td>
            <td>@Model.Mobile</td>
        </tr>

        <tr>
            <td class="label">Gender</td>
            <td>@Model.Gender</td>
        </tr>

        <tr>
            <td class="label">Date Of Birth</td>
            <td>@Model.DOB.ToString("dd-MM-yyyy")</td>
        </tr>

        <tr>
            <td class="label">Family Members</td>
            <td>@Model.TotalMembers</td>
        </tr>

    </table>

    <div class="btn-group">

        <a asp-action="Dashboard" class="btn btn-white">
            Dashboard
        </a>

        <a asp-controller="Account" asp-action="Logout" class="btn btn-white">
            Logout
        </a>

    </div>

</div>