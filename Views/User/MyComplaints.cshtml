@model IEnumerable<Society_Management_System.Models.Complaint>

@{
    Layout = null;
    ViewData["Title"] = "My Complaints";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>
    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI', sans-serif;
        background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('/images/addhouse.png');
        background-size: cover;
        background-position: center;
        display: flex;
        justify-content: center;
        align-items: flex-start;
        padding-top: 50px;
    }

    .page-card {
        width: 95%;
        max-width: 1000px;
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
        padding: 30px;
    }

    .page-title {
        font-size: 28px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 25px;
        color: white;
    }

    .table {
        color: white;
    }

        .table thead {
            background: rgba(0,114,255,0.85);
        }

    .table-hover tbody tr:hover {
        background: rgba(255,255,255,0.1);
    }

    .table-bordered {
        border-color: rgba(255,255,255,0.3);
    }

    .badge-pending {
        background: #dc3545;
        padding: 4px 10px;
        border-radius: 8px;
    }

    .badge-solved {
        background: #28a745;
        padding: 4px 10px;
        border-radius: 8px;
    }

    .btn {
        border-radius: 8px;
        padding: 5px 12px;
    }

    .btn-warning {
        background-color: #ffc107;
        border: none;
        color: black;
    }

    .btn-danger {
        background-color: #dc3545;
        border: none;
        color: white;
    }

    .no-data {
        text-align: center;
        padding: 15px;
        font-style: italic;
        color: #fff;
    }
</style>

<div class="page-card">

    <div class="page-title">My Complaints</div>

    <div class="table-responsive">
        <table class="table table-bordered table-hover text-center">
            <thead>
                <tr>
                    <th>Complaint Id</th>
                    <th>Complaint</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>
                @if (Model.Any())
                {
                    foreach (var c in Model)
                    {
                        <tr>
                            <td>@c.ComplaintId</td>
                            <td>@c.ComplaintText</td>
                            <td>
                                @if (c.Status == "Solved")
                                {
                                    <span class="badge-solved">Solved</span>
                                }
                                else
                                {
                                    <span class="badge-pending">Pending</span>
                                }
                            </td>
                            <td>@c.ComplaintDate.ToString("dd-MM-yyyy")</td>
                            <td>
                                <a asp-controller="User" asp-action="EditComplaint" asp-route-id="@c.ComplaintId" class="btn btn-warning btn-sm">Edit</a>
                                <a asp-controller="User" asp-action="DeleteComplaint" asp-route-id="@c.ComplaintId" class="btn btn-danger btn-sm" onclick="return confirm('Are you sure you want to delete this complaint?');">Delete</a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="no-data">No complaints submitted yet</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>