@model Society_Management_System.Models.Member

@{
    Layout = null;
    ViewData["Title"] = "Edit Member";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI',sans-serif;
        background: linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),url('/images/addhouse.png');
        background-size: cover;
        background-position: center;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* GLASS CARD */

    .form-card {
        width: 100%;
        max-width: 600px;
        padding: 35px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
    }
        /* TITLE */

        .form-card h2 {
            text-align: center;
            margin-bottom: 20px;
        }

    /* INPUT */

    .form-control {
        background: rgba(255,255,255,0.18);
        border: none;
        color: white;
    }

        .form-control:focus {
            background: rgba(255,255,255,0.25);
            box-shadow: none;
        }

    /* BUTTON GROUP */

    .button-group {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 15px;
        justify-content: center;
    }

    /* BUTTON */

    .btn-soft {
        background: linear-gradient(45deg,#00c6ff,#0072ff);
        border: none;
        color: white;
    }

        .btn-soft:hover {
            transform: scale(1.05);
        }

</style>

<div class="form-card">

    <h2>Edit Member</h2>

    <form asp-action="EditMember" method="post">

        <input type="hidden" asp-for="MemberId" />

        <div class="mb-2">
            <label>Name</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Password</label>
            <input asp-for="Password" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Gender</label>
            <select asp-for="Gender" class="form-control">
                <option>Male</option>
                <option>Female</option>
            </select>
        </div>

        <div class="mb-2">
            <label>Date Of Birth</label>
            <input asp-for="DOB" type="date" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Total Members</label>
            <input asp-for="TotalMembers" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Email</label>
            <input asp-for="Email" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Mobile</label>
            <input asp-for="Mobile" class="form-control" />
        </div>

        <div class="button-group">

            <button type="submit" class="btn btn-soft">
                Update Member
            </button>

            <a asp-controller="Admin" asp-action="ViewMembers" class="btn btn-primary">
                Back
            </a>

            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
                Dashboard
            </a>

        </div>

    </form>

</div>