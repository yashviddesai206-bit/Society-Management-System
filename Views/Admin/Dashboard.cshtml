@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>Admin Dashboard</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>

        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(rgba(0,0,0,0.65),rgba(0,0,0,0.65)), url('/images/dashboard.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
        }

        /* ===== SIDEBAR ===== */

        .sidebar {
            width: 240px;
            height: 100vh;
            background: rgba(30,41,59,0.95);
            position: fixed;
            left: 0;
            top: 0;
            padding: 20px;
            color: white;
            backdrop-filter: blur(6px);
        }

            .sidebar h4 {
                text-align: center;
                margin-bottom: 30px;
            }

            .sidebar a {
                display: block;
                padding: 12px 15px;
                color: #cbd5e1;
                text-decoration: none;
                border-radius: 8px;
                margin-bottom: 6px;
                transition: .2s;
            }

                .sidebar a:hover {
                    background: #3b82f6;
                    color: white;
                }

        /* ===== MAIN CONTENT ===== */

        .main {
            margin-left: 240px;
            padding: 30px;
        }

        /* ===== TOPBAR ===== */

        .topbar {
            background: rgba(255,255,255,0.9);
            backdrop-filter: blur(8px);
            border-radius: 12px;
            padding: 15px 25px;
            display: flex;
            justify-content: space-between;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
            margin-bottom: 30px;
        }

        /* ===== CARDS ===== */

        .dashboard-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit,minmax(220px,1fr));
            gap: 25px;
        }

        .card-box {
            background: rgba(255,255,255,0.92);
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 6px 20px rgba(0,0,0,0.12);
            transition: .3s;
        }

            .card-box:hover {
                transform: translateY(-6px);
            }

            .card-box i {
                font-size: 28px;
                margin-bottom: 10px;
            }

        /* CARD COLORS */

        .card1 i {
            color: #3b82f6;
        }

        .card2 i {
            color: #10b981;
        }

        .card3 i {
            color: #f59e0b;
        }

        .card4 i {
            color: #ef4444;
        }

        /* ===== MODULE ===== */

        .module-section {
            margin-top: 40px;
        }

        .module-card {
            background: rgba(255,255,255,0.92);
            border-radius: 15px;
            padding: 25px;
            text-align: center;
            box-shadow: 0 6px 20px rgba(0,0,0,0.12);
            transition: .3s;
        }

            .module-card:hover {
                transform: translateY(-6px);
            }

            .module-card i {
                font-size: 30px;
                color: #3b82f6;
                margin-bottom: 10px;
            }

    </style>

</head>

<body>

    <!-- SIDEBAR -->

    <div class="sidebar">

        <h4><i class="fa fa-building"></i> Society Admin</h4>

        <a href="/Admin/Dashboard"><i class="fa fa-chart-line"></i> Dashboard</a>
        <a href="/Admin/AddSociety"><i class="fa fa-city"></i> Add Society</a>
        <a href="/Admin/ViewSocieties"><i class="fa fa-building"></i> View Societies</a>
        <a href="/Admin/AddHouse"><i class="fa fa-house"></i> Add House</a>
        <a href="/Admin/ViewMembers"><i class="fa fa-users"></i> Members</a>
        <a href="/Admin/ViewComplaints"><i class="fa fa-triangle-exclamation"></i> Complaints</a>
        <a href="/Account/Logout"><i class="fa fa-right-from-bracket"></i> Logout</a>

    </div>

    <!-- MAIN CONTENT -->

    <div class="main">

        <div class="topbar">

            <h5>Admin Dashboard</h5>
            <span>Welcome Admin</span>

        </div>

        <!-- STAT CARDS -->

        <div class="dashboard-cards">

            <div class="card-box card1">

                <i class="fa fa-city"></i>

                <h6>Total Societies</h6>

                <h3>@ViewBag.TotalSociety</h3>

            </div>

            <div class="card-box card2">

                <i class="fa fa-house"></i>

                <h6>Total Houses</h6>

                <h3>@ViewBag.TotalHouse</h3>

            </div>

            <div class="card-box card3">

                <i class="fa fa-users"></i>

                <h6>Total Members</h6>

                <h3>@ViewBag.TotalMember</h3>

            </div>

            <div class="card-box card4">

                <i class="fa fa-exclamation-circle"></i>

                <h6>Total Complaints</h6>

                <h3>@ViewBag.TotalComplaint</h3>

            </div>

        </div>

        <!-- MODULES -->

        <div class="module-section">

            <h4 class="mb-4">Quick Management</h4>

            <div class="row g-4">

                <div class="col-md-4">

                    <div class="module-card">

                        <i class="fa fa-city"></i>

                        <h5>Add Society</h5>

                        <a href="/Admin/AddSociety" class="btn btn-primary btn-sm">Open</a>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="module-card">

                        <i class="fa fa-house"></i>

                        <h5>Add House</h5>

                        <a href="/Admin/AddHouse" class="btn btn-primary btn-sm">Open</a>

                    </div>

                </div>

                <div class="col-md-4">

                    <div class="module-card">

                        <i class="fa fa-users"></i>

                        <h5>Add Members</h5>

                        <a href="/Admin/AddMember" class="btn btn-primary btn-sm">Open</a>

                    </div>

                </div>

            </div>

        </div>

    </div>

</body>

</html>