@model Society_Management_System.Models.Member

@{
    Layout = null;
    ViewData["Title"] = "Add Member";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

<style>

    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI',sans-serif;
        background: linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),url('/images/addhouse.png');
        background-size: cover;
        background-position: center;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    /* GLASS CARD */

    .form-card {
        width: 100%;
        max-width: 600px;
        padding: 35px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
    }

        /* TITLE */

        .form-card h2 {
            text-align: center;
            margin-bottom: 20px;
            font-size: 24px;
        }

    /* LABEL */

    label {
        margin-bottom: 4px;
        font-size: 14px;
    }

    /* INPUT */

    .form-control {
        background: rgba(255,255,255,0.18);
        border: none;
        color: white;
        border-radius: 8px;
        height: 38px;
    }

        .form-control::placeholder {
            color: #ddd;
        }

        .form-control:focus {
            background: rgba(255,255,255,0.25);
            box-shadow: none;
        }

    /* SELECT */

    select {
        background: rgba(255,255,255,0.18);
        color: white;
    }

    /* BUTTON GROUP */

    .button-group {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 15px;
        justify-content: center;
    }

    /* BUTTON */

    .btn-add {
        background: linear-gradient(45deg,#00c6ff,#0072ff);
        border: none;
        color: white;
    }

        .btn-add:hover {
            transform: scale(1.05);
        }

</style>

<div class="form-card">

    <h2><i class="fa-solid fa-user-plus"></i> Add Member</h2>

    <form asp-action="AddMember" method="post" enctype="multipart/form-data">

        <div class="mb-2">
            <label>Name</label>
            <input asp-for="Name" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Password</label>
            <input asp-for="Password" type="password" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Gender</label>
            <select asp-for="Gender" class="form-control">
                <option value="">Select Gender</option>
                <option>Male</option>
                <option>Female</option>
            </select>
        </div>

        <div class="mb-2">
            <label>Date of Birth</label>
            <input asp-for="DOB" type="date" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Total Members</label>
            <input asp-for="TotalMembers" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Email</label>
            <input asp-for="Email" class="form-control" />
        </div>

        <div class="mb-2">
            <label>Mobile</label>
            <input asp-for="Mobile" class="form-control" />
        </div>

        <div class="button-group">

            <button type="submit" class="btn btn-add">
                <i class="fa-solid fa-plus"></i> Add
            </button>

            <a asp-controller="Admin" asp-action="ViewMembers" class="btn btn-primary">
                View
            </a>

            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
                Back
            </a>

        </div>

    </form>

</div>