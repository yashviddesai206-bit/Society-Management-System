@model SOCITEY_MANAGEMENT.Models.House

@{
    Layout = null;
    ViewData["Title"] = "Add House";
}

<!DOCTYPE html>

<html>

<head>

    ```
    <meta name="viewport" content="width=device-width" />

    <title>Add House</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    ```

    <style>

        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(rgba(0,0,0,0.55),rgba(0,0,0,0.55)), url('/images/addhouse.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* GLASS FORM CARD */

        .form-card {
            width: 100%;
            max-width: 600px;
            padding: 35px;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(12px);
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            color: white;
        }

            /* TITLE */

            .form-card h2 {
                text-align: center;
                margin-bottom: 25px;
                color: white;
            }

        /* INPUT */

        .form-control {
            background: rgba(255,255,255,0.15);
            border: none;
            color: white;
        }

            .form-control::placeholder {
                color: #ddd;
            }

            .form-control:focus {
                background: rgba(255,255,255,0.2);
                box-shadow: none;
            }

        /* SELECT */

        select {
            background: rgba(255,255,255,0.15);
            color: white;
            border: none;
        }

        /* BUTTON */

        .btn-soft {
            background: linear-gradient(45deg,#00c6ff,#0072ff);
            color: white;
            border: none;
            border-radius: 8px;
            padding: 8px 16px;
        }

            .btn-soft:hover {
                transform: scale(1.05);
            }

        /* BUTTON GROUP */

        .button-group {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }

    </style>

</head>

<body>

    <div class="form-card">

        <h2>Add House</h2>

        <form asp-action="AddHouse" asp-controller="Admin" method="post">

            <select asp-for="SocietyId" asp-items="ViewBag.SocietyList" class="form-control mb-3">
                <option value="">Select Society</option>
            </select>

            <div class="mb-3">
                <label class="form-label">House Number</label>
                <input asp-for="HouseNumber" class="form-control" placeholder="Enter House Number" />
            </div>

            <div class="mb-3">
                <label class="form-label">Block Number</label>
                <input asp-for="BlockNumber" class="form-control" placeholder="Enter Block Number" />
            </div>

            <div class="mb-3">
                <label class="form-label">House Type</label>
                <input asp-for="HouseType" class="form-control" placeholder="Example: 1BHK / 2BHK" />
            </div>

            <div class="mb-3">
                <label class="form-label">Details</label>
                <input asp-for="Details" class="form-control" placeholder="Extra details" />
            </div>

            <div class="mb-3">
                <label class="form-label">Status</label>

                <select asp-for="Status" class="form-control">
                    <option value="">Select Status</option>
                    <option>Available</option>
                    <option>Allocated</option>
                </select>

            </div>

            <div class="button-group">

                <button type="submit" class="btn btn-soft">
                    Add House
                </button>

                <a asp-controller="Admin" asp-action="ViewHouses" class="btn btn-primary">
                    View Houses
                </a>

                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
                    Back to Dashboard
                </a>

            </div>

        </form>

    </div>

</body>

</html>
