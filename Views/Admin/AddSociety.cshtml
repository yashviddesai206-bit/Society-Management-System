@model Society_Management_System.Models.Society

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <title>Add Society</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(rgba(0,0,0,0.6),rgba(0,0,0,0.6)),url('/images/addhouse.png');
            background-size: cover;
            background-position: center;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        /* GLASS CARD */

        .form-card {
            width: 90%;
            max-width: 480px;
            padding: 25px;
            background: rgba(255,255,255,0.15);
            backdrop-filter: blur(12px);
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
            color: white;
        }

            /* TITLE */

            .form-card h3 {
                text-align: center;
                margin-bottom: 20px;
            }

        /* INPUT */

        .form-control {
            background: rgba(255,255,255,0.18);
            border: none;
            color: white;
            border-radius: 8px;
        }

            .form-control:focus {
                background: rgba(255,255,255,0.25);
                box-shadow: none;
            }

        /* TEXTAREA */

        textarea {
            background: rgba(255,255,255,0.18);
            color: white;
            border: none;
        }

        /* BUTTON GROUP */

        .button-group {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 15px;
            justify-content: center;
        }

        /* ADD BUTTON */

        .btn-soft {
            background: linear-gradient(45deg,#00c6ff,#0072ff);
            border: none;
            color: white;
        }

            .btn-soft:hover {
                transform: scale(1.05);
            }

        /* ALERT */

        .alert-success {
            text-align: center;
        }

    </style>

</head>

<body>

    <div class="form-card">

        <h3>Add New Society</h3>

        @if (ViewBag.Message != null)
        {
            <div class="alert alert-success">@ViewBag.Message</div>
        }

        <form asp-controller="Admin" asp-action="AddSociety" method="post" enctype="multipart/form-data">

            <div class="mb-2">
                <label>Society Name</label>
                <input asp-for="SocietyName" class="form-control" />
            </div>

            <div class="mb-2">
                <label>City</label>
                <input asp-for="City" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Pin Code</label>
                <input asp-for="PinCode" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Total Houses</label>
                <input asp-for="TotalHouses" type="number" class="form-control" />
            </div>

            <div class="mb-2">
                <label>Address</label>
<textarea asp-for="Address" class="form-control"></textarea>
            </div>

            <div class="mb-2">
                <label>Image</label>
                <input type="file" name="ImageFile" class="form-control" />
            </div>

            <div class="button-group">

                <button type="submit" class="btn btn-soft">
                    Add Society
                </button>

                <a asp-controller="Admin" asp-action="ViewSocieties" class="btn btn-primary">
                    View
                </a>

                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
                    Back
                </a>

            </div>

        </form>

    </div>

</body>
</html>