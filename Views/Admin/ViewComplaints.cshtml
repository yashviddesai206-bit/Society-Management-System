@model List<Society_Management_System.Models.Complaint>

@{
    Layout = null;
    ViewData["Title"] = "Member Complaints";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI',sans-serif;
        background: linear-gradient(rgba(0,0,0,0.55),rgba(0,0,0,0.55)),url('/images/addhouse.png');
        background-size: cover;
        background-position: center;
        display: flex;
        justify-content: center;
    }

    /* GLASS CARD */

    .page-card {
        width: 95%;
        max-width: 1000px;
        margin-top: 40px;
        padding: 30px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
    }

    /* TITLE */

    .page-title {
        font-size: 26px;
        font-weight: 700;
        text-align: center;
        margin-bottom: 20px;
    }

    /* TABLE */

    .table {
        color: white;
    }

        .table thead {
            background: rgba(0,114,255,0.85);
        }

    .table-hover tbody tr:hover {
        background: rgba(255,255,255,0.1);
    }

    .table-bordered {
        border-color: rgba(255,255,255,0.3);
    }

</style>

<div class="page-card">

    <div class="page-title">Member Complaints</div>

    <div class="table-responsive">
        <a asp-action="AddHouse" asp-controller="Admin" class="btn btn-soft">
            Add House
        </a>

        <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
            Dashboard
        </a>


        <table class="table table-bordered table-hover text-center">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Member Id</th>
                    <th>Complaint</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6">No Complaints Found</td>
                    </tr>
                }

                @foreach (var item in Model)
                {
                    <tr>

                        <td>@item.ComplaintId</td>

                        <td>@item.MemberId</td>

                        <td class="text-start">@item.ComplaintText</td>

                        <td>@item.Status</td>

                        <td>@item.ComplaintDate.ToShortDateString()</td>

                        <td>
                            <a asp-controller="Admin"
                               asp-action="EditComplaint"
                               asp-route-id="@item.ComplaintId"
                               class="btn btn-warning btn-sm">
                                View / Reply
                            </a>
                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>