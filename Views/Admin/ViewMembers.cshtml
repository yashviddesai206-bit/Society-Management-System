@model List<Society_Management_System.Models.Member>

@{
    Layout = null;
    ViewData["Title"] = "Members List";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

<style>

    body {
        min-height: 100vh;
        margin: 0;
        font-family: 'Segoe UI',sans-serif;
        background: linear-gradient(rgba(0,0,0,0.55),rgba(0,0,0,0.55)),url('/images/addhouse.png');
        background-size: cover;
        background-position: center;
    }

    /* GLASS CARD */

    .page-card {
        width: 95%;
        max-width: 1000px;
        margin: 40px auto;
        padding: 30px;
        background: rgba(255,255,255,0.12);
        backdrop-filter: blur(12px);
        border-radius: 18px;
        border: 1px solid rgba(255,255,255,0.3);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        color: white;
    }

    /* TITLE */

    .page-title {
        font-size: 26px;
        font-weight: 700;
    }

    /* BUTTONS */

    .btn-soft {
        background: linear-gradient(45deg,#00c6ff,#0072ff);
        border: none;
        color: white;
    }

        .btn-soft:hover {
            transform: scale(1.05);
        }

    .button-group {
        display: flex;
        gap: 10px;
    }

    /* TABLE */

    .table {
        color: white;
    }

        .table thead {
            background: rgba(0,114,255,0.85);
        }

    .table-hover tbody tr:hover {
        background: rgba(255,255,255,0.1);
    }

    .table-bordered {
        border-color: rgba(255,255,255,0.3);
    }

    .member-count {
        background: #00c6ff;
        padding: 4px 10px;
        border-radius: 8px;
    }

    .action-btns {
        display: flex;
        justify-content: center;
        gap: 8px;
    }

</style>

<div class="page-card">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <div class="page-title">Members List</div>

        <div class="button-group">

            <a asp-controller="Admin" asp-action="AddMember" class="btn btn-soft">
                Add Member
            </a>

            <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
                Dashboard
            </a>

        </div>

    </div>

    <div class="table-responsive">

        <table class="table table-bordered table-hover text-center">

            <thead>
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Mobile</th>
                    <th>Total Members</th>
                    <th>Action</th>
                </tr>
            </thead>

            <tbody>

                @if (Model.Count == 0)
                {
                    <tr>
                        <td colspan="6">No Members Found</td>
                    </tr>
                }

                @foreach (var m in Model)
                {
                    <tr>

                        <td>@m.MemberId</td>
                        <td>@m.Name</td>
                        <td>@m.Email</td>
                        <td>@m.Mobile</td>

                        <td>
                            <span class="member-count">@m.TotalMembers</span>
                        </td>

                        <td>

                            <div class="action-btns">

                                <a asp-controller="Admin"
                                   asp-action="EditMember"
                                   asp-route-id="@m.MemberId"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-controller="Admin"
                                   asp-action="DeleteMember"
                                   asp-route-id="@m.MemberId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Delete this member?')">
                                    Delete
                                </a>

                            </div>

                        </td>

                    </tr>
                }

            </tbody>

        </table>

    </div>

</div>