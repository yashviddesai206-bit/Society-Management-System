@model List<Society_Management_System.Models.Society>

@{
    Layout = null;
    ViewData["Title"] = "Society List";
}

<!DOCTYPE html>
<html>
<head>

    <meta charset="utf-8" />
    <title>Society List</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>

        body {
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(rgba(0,0,0,0.55),rgba(0,0,0,0.55)),url('/images/addhouse.png');
            background-size: cover;
            background-position: center;
        }

        /* GLASS CARD */

        .page-card {
            width: 95%;
            max-width: 1100px;
            margin: 40px auto;
            padding: 30px;
            background: rgba(255,255,255,0.12);
            backdrop-filter: blur(12px);
            border-radius: 18px;
            border: 1px solid rgba(255,255,255,0.3);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        
        }

        /* TITLE */

        .page-title {
            font-size: 26px;
            font-weight: 700;
        }

        /* BUTTON */

        .btn-soft {
            background: linear-gradient(45deg,#00c6ff,#0072ff);
            border: none;
           
        }

            .btn-soft:hover {
                transform: scale(1.05);
            }

        .button-group {
            display: flex;
            gap: 10px;
        }

        /* TABLE */

    

            .table thead {
                background: rgba(0,114,255,0.85);
            }

        .table-hover tbody tr:hover {
            background: rgba(255,255,255,0.1);
        }

        .table-bordered {
            border-color: rgba(255,255,255,0.3);
        }

        .society-img {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            object-fit: cover;
        }

    </style>

</head>

<body>

    <div class="page-card">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div class="page-title">Society List</div>

            <div class="button-group">

                <a asp-controller="Admin" asp-action="AddSociety" class="btn btn-soft">
                    Add Society
                </a>

                <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-secondary">
                    Dashboard
                </a>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-bordered table-hover text-center">

                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Society Name</th>
                        <th>City</th>
                        <th>Pin Code</th>
                        <th>Total Houses</th>
                        <th>Address</th>
                        <th>Image</th>
                        <th>Actions</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="8">No Society Found</td>
                        </tr>
                    }

                    @foreach (var s in Model)
                    {
                        <tr>

                            <td>@s.SocietyId</td>
                            <td>@s.SocietyName</td>
                            <td>@s.City</td>
                            <td>@s.PinCode</td>
                            <td>@s.TotalHouses</td>
                            <td class="text-start">@s.Address</td>

                            <td>
                                @if (!string.IsNullOrEmpty(s.Image))
                                {
                                    <img src="@s.Image" class="society-img" />
                                }
                            </td>

                            <td>

                                <a asp-controller="Admin"
                                   asp-action="EditSociety"
                                   asp-route-id="@s.SocietyId"
                                   class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-controller="Admin"
                                   asp-action="DeleteSociety"
                                   asp-route-id="@s.SocietyId"
                                   class="btn btn-danger btn-sm"
                                   onclick="return confirm('Are you sure you want to delete this society?')">
                                    Delete
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>

</body>
</html>