@model Society_Management_System.Models.LoginViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>

    <meta charset="utf-8" />
    <title>Society Management Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <style>

        /* ================= BODY ================= */
        body {
            height: 100vh;
            margin: 0;
            font-family: 'Segoe UI',sans-serif;
            background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('/images/login.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        body {
            background-image: url('/images/login.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            height: 100vh;
        }

        /* ================= LOGIN CARD ================= */

        .login-card {
            width: 420px;
            padding: 40px;
            border-radius: 20px;
            background: rgba(255,255,255,0.08);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 15px 40px rgba(0,0,0,0.5);
            color: white;
            transition: 0.3s;
        }

            .login-card:hover {
                transform: translateY(-5px);
            }

        /* ================= TITLE ================= */

        .title {
            text-align: center;
            font-size: 30px;
            font-weight: 700;
        }

        .subtitle {
            text-align: center;
            margin-bottom: 30px;
            opacity: 0.8;
        }

        /* ================= INPUT ================= */

        .input-group {
            margin-bottom: 20px;
        }

        .input-group-text {
            background: rgba(255,255,255,0.1);
            border: none;
            color: white;
        }

        .form-control {
            background: rgba(255,255,255,0.1);
            border: none;
            color: white;
        }

            .form-control::placeholder {
                color: #ddd;
            }

            .form-control:focus {
                box-shadow: none;
                background: rgba(255,255,255,0.15);
            }

        /* ================= BUTTON ================= */

        .btn-login {
            width: 100%;
            padding: 12px;
            border: none;
            border-radius: 10px;
            background: linear-gradient(45deg,#00c6ff,#0072ff);
            color: white;
            font-weight: 600;
            transition: 0.3s;
        }

            .btn-login:hover {
                transform: scale(1.05);
                box-shadow: 0 5px 20px rgba(0,114,255,0.6);
            }

        /* ================= LINKS ================= */

        .extra-links {
            margin-top: 15px;
            display: flex;
            justify-content: space-between;
        }

            .extra-links a {
                color: #ddd;
                text-decoration: none;
                font-size: 14px;
            }

                .extra-links a:hover {
                    color: white;
                }

        /* ================= FOOTER ================= */

        .footer-text {
            text-align: center;
            margin-top: 25px;
            font-size: 13px;
            opacity: 0.8;
        }

    </style>

</head>

<body>

    <div class="login-card">

        <div class="title">
            <i class="fa-solid fa-building"></i> Society Management
        </div>

        <div class="subtitle">
            Secure Login Portal
        </div>

        <div asp-validation-summary="All" class="text-danger"></div>

        <form asp-controller="Account" asp-action="Login" method="post">

            <div class="input-group">

                <span class="input-group-text">
                    <i class="fa-solid fa-envelope"></i>
                </span>

                <input asp-for="Email" class="form-control" placeholder="Enter Email" required />

            </div>

            <div class="input-group">

                <span class="input-group-text">
                    <i class="fa-solid fa-lock"></i>
                </span>

                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       id="password"
                       placeholder="Enter Password"
                       required />

                <span class="input-group-text" onclick="togglePassword()" style="cursor:pointer;">
                    <i class="fa-solid fa-eye"></i>
                </span>

            </div>

            <button type="submit" class="btn-login">
                <i class="fa-solid fa-right-to-bracket"></i> Sign In
            </button>

            <div class="extra-links">

                <a asp-controller="Account" asp-action="ForgotPassword">
                    Forgot Password
                </a>

                <a asp-controller="Admin" asp-action="AddMember">
                    Register
                </a>

            </div>

        </form>

        <div class="footer-text">
            © 2026 Society Management System
        </div>

    </div>

    <script>

        function togglePassword(){

        var x=document.getElementById("password");

        if(x.type==="password"){
        x.type="text";
        }else{
        x.type="password";
        }

        }

    </script>

</body>

</html>